    "smoke:security-hardening": "LOG_LEVEL=silent node --import tsx scripts/smoke-security-hardening.ts",
    "smoke:correlation": "LOG_LEVEL=silent node --import tsx scripts/smoke-correlation.ts",
    "smoke:readiness": "LOG_LEVEL=silent node --import tsx scripts/smoke-readiness.ts",
    "smoke:deployment-preflight": "LOG_LEVEL=silent node --import tsx scripts/smoke-deployment-preflight.ts",
    "smoke:deployment-preflight-cli": "LOG_LEVEL=silent node --import tsx scripts/smoke-deployment-preflight-cli.ts",
    "smoke:deployment-readiness-packet": "LOG_LEVEL=silent node --import tsx scripts/smoke-deployment-readiness-packet.ts",
