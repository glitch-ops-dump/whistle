# Whistle MVP1 remote TEST runtime template.
# Copy this into the approved test secret manager, replace every REPLACE_WITH_* value,
# then render it into the API/worker deployment environment. Do not deploy this file as-is.
#
# TEST is for functional/UAT validation only. It is not staging or production launch
# evidence, and it may use hidden mock OTP, mock notifications, and local evidence
# storage on persistent test disk.

WHISTLE_DEPLOYMENT_PROFILE=test
DATABASE_URL=REPLACE_WITH_TEST_POSTGRES_URL
WHISTLE_SEED_DEMO=false

# Government console identity for TEST.
# TEST may use seeded mobile/password government accounts. Keep prototype role
# headers disabled so console flows use sessions, not x-whistle-role shortcuts.
# Staging/production still require approved OIDC/MFA unless a formal policy
# approves mobile/password + OTP for officials.
WHISTLE_PROTOTYPE_OFFICIAL_AUTH=false

# Worker runtime. Required in TEST because remote workers must not be open.
WHISTLE_WORKER_AUTH_REQUIRED=true
WHISTLE_WORKER_SHARED_SECRET=REPLACE_WITH_TEST_WORKER_SHARED_SECRET

# Citizen OTP. TEST may use hidden mock OTP so user flows can be rehearsed before
# production SMS/WhatsApp contracts are ready. Never expose OTP in API responses.
WHISTLE_EXPOSE_MOCK_OTP=false

# Evidence object storage. TEST may use the local object-store implementation if
# this path is backed by persistent test disk. Do not use for real citizen data.
WHISTLE_EVIDENCE_STORE_DIR=REPLACE_WITH_TEST_PERSISTENT_EVIDENCE_DIR

# Public rate limiting. Use Postgres so multiple API instances share limits.
WHISTLE_RATE_LIMIT_BACKEND=postgres
WHISTLE_RATE_LIMIT_KEY_SALT=REPLACE_WITH_TEST_RATE_LIMIT_HASH_SALT

# Browser/API edge. Replace these with the actual remote TEST frontend origins.
WHISTLE_ALLOWED_ORIGINS=REPLACE_WITH_TEST_CITIZEN_ORIGIN,REPLACE_WITH_TEST_CONSOLE_ORIGIN
WHISTLE_SECURITY_HEADERS_ENABLED=true

# Optional TEST-only observability. If left unset, TEST uses local request metrics
# and local security export behavior. Configure webhook/OTLP only when you want to
# test those integrations before staging.
# WHISTLE_SECURITY_EXPORT_MODE=webhook
# WHISTLE_SECURITY_EXPORT_WEBHOOK_URL=REPLACE_WITH_TEST_SECURITY_EXPORT_WEBHOOK_URL
# WHISTLE_SECURITY_EXPORT_API_KEY=REPLACE_WITH_TEST_SECURITY_EXPORT_API_KEY
# WHISTLE_TELEMETRY_EXPORT_MODE=otlp-http
# WHISTLE_OTEL_EXPORTER_OTLP_ENDPOINT=REPLACE_WITH_TEST_OTEL_COLLECTOR_ENDPOINT
