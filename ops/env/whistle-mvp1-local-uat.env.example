# Whistle MVP1 local UAT runtime.
# This file is intentionally local-only. It uses smoke secrets and local Postgres
# to exercise OIDC-token auth, worker-token auth, and shared rate limits together.
# It must never be used as staging or production secret material.

DATABASE_URL=postgres://whistle:whistle@localhost:54329/whistle
WHISTLE_DEPLOYMENT_PROFILE=local
WHISTLE_SEED_DEMO=false

# Government console auth: local HS256 OIDC smoke token path only.
WHISTLE_PROTOTYPE_OFFICIAL_AUTH=false
WHISTLE_OFFICIAL_OIDC_ISSUER=https://id.local.whistle.test/realms/whistle
WHISTLE_OFFICIAL_OIDC_AUDIENCE=whistle-government-console
WHISTLE_OFFICIAL_OIDC_HS256_SECRET=local-mvp1-oidc-smoke-secret-do-not-use-for-staging-or-production
WHISTLE_OFFICIAL_OIDC_MFA_REQUIRED=true

# Worker jobs must use a shared token in UAT.
WHISTLE_WORKER_AUTH_REQUIRED=true
WHISTLE_WORKER_SHARED_SECRET=local-mvp1-worker-smoke-secret-do-not-use-for-staging-or-production

# Keep public abuse controls shared across local API instances.
WHISTLE_RATE_LIMIT_BACKEND=postgres
WHISTLE_RATE_LIMIT_KEY_SALT=local-mvp1-rate-limit-smoke-salt

# Hide mock OTP values from API responses in local UAT. This still is not a real
# SMS provider, so deployment preflight must continue to show the OTP provider
# as an external launch gate.
WHISTLE_EXPOSE_MOCK_OTP=false

WHISTLE_SECURITY_HEADERS_ENABLED=true
WHISTLE_ALLOWED_ORIGINS=http://localhost:5185,http://127.0.0.1:5185
