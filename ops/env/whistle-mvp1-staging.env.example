# Whistle MVP1 staging env template.
# Copy this into the approved secret manager, replace every REPLACE_WITH_* value,
# then render it into the deployment environment. Do not deploy this file as-is.

WHISTLE_DEPLOYMENT_PROFILE=staging
DATABASE_URL=REPLACE_WITH_POSTGRES_URL

# Government console identity. HS256 is local-smoke only; do not set it here.
WHISTLE_PROTOTYPE_OFFICIAL_AUTH=false
WHISTLE_OFFICIAL_OIDC_ISSUER=REPLACE_WITH_HTTPS_OIDC_ISSUER
WHISTLE_OFFICIAL_OIDC_AUDIENCE=whistle-government-console
WHISTLE_OFFICIAL_OIDC_JWKS_URL=REPLACE_WITH_HTTPS_OIDC_JWKS_URL
WHISTLE_OFFICIAL_OIDC_MFA_REQUIRED=true

# Worker runtime.
WHISTLE_WORKER_AUTH_REQUIRED=true
WHISTLE_WORKER_SHARED_SECRET=REPLACE_WITH_WORKER_SHARED_SECRET

# Citizen OTP.
WHISTLE_OTP_PROVIDER_MODE=webhook
WHISTLE_OTP_PROVIDER_WEBHOOK_URL=REPLACE_WITH_OTP_WEBHOOK_URL
WHISTLE_OTP_PROVIDER_API_KEY=REPLACE_WITH_OTP_PROVIDER_API_KEY
WHISTLE_EXPOSE_MOCK_OTP=false

# Evidence object storage, encryption, and scanner declaration.
WHISTLE_EVIDENCE_OBJECT_STORE_MODE=s3-compatible
WHISTLE_EVIDENCE_S3_ENDPOINT=REPLACE_WITH_S3_COMPATIBLE_ENDPOINT
WHISTLE_EVIDENCE_S3_BUCKET=REPLACE_WITH_PRIVATE_EVIDENCE_BUCKET
WHISTLE_EVIDENCE_S3_REGION=ap-south-1
WHISTLE_EVIDENCE_KMS_KEY_ID=REPLACE_WITH_EVIDENCE_KMS_KEY_ID
WHISTLE_EVIDENCE_MALWARE_SCANNER_CONFIGURED=true
WHISTLE_EVIDENCE_DATA_RESIDENCY=India

# Citizen notifications.
WHISTLE_NOTIFICATION_PROVIDER_MODE=webhook
WHISTLE_NOTIFICATION_PROVIDER_WEBHOOK_URL=REPLACE_WITH_NOTIFICATION_WEBHOOK_URL
WHISTLE_NOTIFICATION_PROVIDER_API_KEY=REPLACE_WITH_NOTIFICATION_PROVIDER_API_KEY

# Public rate limiting.
WHISTLE_RATE_LIMIT_BACKEND=gateway
WHISTLE_RATE_LIMIT_GATEWAY_URL=REPLACE_WITH_RATE_LIMIT_GATEWAY_URL
WHISTLE_RATE_LIMIT_GATEWAY_API_KEY=REPLACE_WITH_RATE_LIMIT_GATEWAY_API_KEY
WHISTLE_RATE_LIMIT_KEY_SALT=REPLACE_WITH_RATE_LIMIT_HASH_SALT

# Browser/API edge.
WHISTLE_ALLOWED_ORIGINS=https://citizen-staging.whistle.example,https://console-staging.whistle.example
WHISTLE_SECURITY_HEADERS_ENABLED=true

# SIEM/WORM audit export.
WHISTLE_SECURITY_EXPORT_MODE=webhook
WHISTLE_SECURITY_EXPORT_WEBHOOK_URL=REPLACE_WITH_SIEM_WORM_WEBHOOK_URL
WHISTLE_SECURITY_EXPORT_API_KEY=REPLACE_WITH_SECURITY_EXPORT_API_KEY

# OpenTelemetry.
WHISTLE_TELEMETRY_EXPORT_MODE=otlp-http
WHISTLE_OTEL_EXPORTER_OTLP_ENDPOINT=REPLACE_WITH_OTEL_COLLECTOR_ENDPOINT

# Operations evidence.
WHISTLE_DEPLOYMENT_RUNBOOK_APPROVED=true
WHISTLE_DEPLOYMENT_RUNBOOK_VERSION=mvp1-ops-2026-06-01
WHISTLE_BACKUP_RESTORE_DRILL_APPROVED=true
WHISTLE_BACKUP_RESTORE_DRILL_AT=REPLACE_WITH_ISO_RESTORE_DRILL_TIMESTAMP
